# ── Well Startup Decision Console · Environment Variables ──────────────────
# Copy this file to .env on your VPS before running docker compose up.
# All values below are the built-in defaults — the stack works out of the box
# WITHOUT a .env file, so this is only needed if you want to customise.

# PostgreSQL credentials (used by both db and api containers)
POSTGRES_USER=wells
POSTGRES_PASSWORD=wells
POSTGRES_DB=wells

# Public hostname for Caddy's reverse proxy.
#   :80            → plain HTTP on every port-80 request (default, IP-based)
#   yourdomain.com → Caddy auto-generates a Let's Encrypt TLS certificate
PUBLIC_HOST=:80

# Email for Let's Encrypt registration (only used when PUBLIC_HOST is a domain)
ACME_EMAIL=
